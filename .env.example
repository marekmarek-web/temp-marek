# =============================================================================
# Premium Brokers — environment contract (zkopíruj do .env.local)
# Nikdy necommitovat reálné tajné klíče.
# =============================================================================

# --- Veřejné (prefix NEXT_PUBLIC_ = může být v client bundle) ---
# Kanonická URL webu (metadata, OG, e-mailové odkazy). Na Vercel často přepíše Production URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — blog, admin, auth (veřejný anon klíč je v prohlížeči, je chráněn RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Nový Supabase dashboard: publishable (`sb_publishable_…`) — stačí jedno z ANON_KEY / PUBLISHABLE_KEY
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Sentry — DSN je veřejný identifikátor projektu (ne tajný). Bez nastavení se chyby jen logují.
NEXT_PUBLIC_SENTRY_DSN=

# Plausible — doména projektu v Plausible (jen název, např. marekpribramsky.cz). Bez toho se analytika nespouští.
# Spouští se až po souhlasu v cookie banneru.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Legacy / kontaktní formulář přes FormSubmit (volitelné)
NEXT_PUBLIC_FORMSUBMIT_URL=

# --- Pouze server (Node.js, API routes, server actions) ---
# Resend — odesílání lead e-mailů
RESEND_API_KEY=
RESEND_FROM=Premium Brokers <onboarding@resend.dev>
LEAD_EMAIL_TO=

# Supabase service role — pouze server (nábor, admin upload); NIKDY do klienta
SUPABASE_SERVICE_ROLE_KEY=

# Sentry — volitelné pro upload source maps v CI (SENTRY_AUTH_TOKEN, org, project)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Kalkulačky — vynutit statické sazby (testování)
# FORCE_STATIC_RATES=true
