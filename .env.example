# Premium Brokers – příklad konfigurace
# Zkopíruj do .env.local a doplň hodnoty

# Veřejná kanonická URL webu (metadata, OG) – např. https://www.marekpribramsky.cz
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (blog, nábor, administrace) — viz supabase/README.md
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Pouze na serveru (náborové přihlášky přes service role, necommitovat)
SUPABASE_SERVICE_ROLE_KEY=

# API / backend (pokud bude)
# API_URL=
# API_KEY=
